{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, PATCH, PUT, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      },
      "continue": true
    },
    { "src": "/api/bookings/stats/summary",  "dest": "/api/bookings/stats/summary.js" },
    { "src": "/api/bookings/availability",   "dest": "/api/bookings/availability.js" },
    { "src": "/api/bookings/([^/]+)/status", "dest": "/api/bookings/[id].js" },
    { "src": "/api/bookings/([^/]+)",        "dest": "/api/bookings/[id].js" },
    { "src": "/api/bookings",                "dest": "/api/bookings.js" },
    { "src": "/api/corporate/register-employee", "dest": "/api/corporate.js" },
    { "src": "/api/corporate/register",          "dest": "/api/corporate.js" },
    { "src": "/api/corporate/validate",          "dest": "/api/corporate.js" },
    { "src": "/api/corporate/complete",          "dest": "/api/corporate.js" },
    { "src": "/api/corporate/companies",         "dest": "/api/corporate.js" },
    { "src": "/api/corporate/employees",         "dest": "/api/corporate.js" },
    { "src": "/api/corporate/stats",             "dest": "/api/corporate.js" },
    { "src": "/api/corporate/company-status",    "dest": "/api/corporate.js" },
    { "src": "/api/corporate/employee-status",   "dest": "/api/corporate.js" },
    { "src": "/api/health",                      "dest": "/api/health.js" }
  ]
}